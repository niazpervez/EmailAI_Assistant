<Application x:Class="EmailAI.WPF.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:EmailAI.WPF.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles/Colors.xaml"/>
                <ResourceDictionary Source="Styles/Base.xaml"/>
                <ResourceDictionary Source="Styles/Controls.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <conv:BoolToVisibilityConverter        x:Key="BoolToVisibility"/>
            <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
            <conv:InverseBoolConverter             x:Key="InverseBool"/>
            <conv:StringNotEmptyConverter          x:Key="StringNotEmpty"/>
            <conv:HexToBrushConverter              x:Key="HexToBrush"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
