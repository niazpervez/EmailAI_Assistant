<UserControl x:Class="EmailAI.WPF.Views.ChatView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:EmailAI.UI.Shared.ViewModels;assembly=EmailAI.UI.Shared"
             xmlns:ctrl="clr-namespace:EmailAI.WPF.Controls">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Session sidebar -->
        <Border Grid.Column="0" Background="{StaticResource NavBgBrush}"
                BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,0,1,0">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Margin="12,16,12,12">
                    <Button Command="{Binding NewSessionCommand}" HorizontalAlignment="Stretch"
                            Style="{StaticResource PrimaryButton}" Padding="12,10" FontSize="12">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="＋" FontSize="16" FontWeight="Bold" Margin="0,0,8,0"/>
                            <TextBlock Text="New Chat" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <TextBlock DockPanel.Dock="Top" Text="RECENT CHATS" FontSize="10" FontWeight="SemiBold"
                           Foreground="{StaticResource TextMutedBrush}" Margin="16,0,0,8"/>

                <ListBox ItemsSource="{Binding Sessions}"
                         SelectedItem="{Binding SelectedSession}"
                         Margin="8,0,8,12" ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         Background="Transparent" BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="10,9" CornerRadius="8" Margin="0,1">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="💬" FontSize="12" Margin="0,0,8,0" Opacity="0.8"/>
                                    <TextBlock Text="{Binding Label}" FontSize="12"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- Chat area -->
        <DockPanel Grid.Column="1" Background="{StaticResource PrimaryBrush}">

            <!-- Input (docked bottom first so it always reserves space) -->
            <Border DockPanel.Dock="Bottom" Padding="20,14"
                    BorderBrush="{StaticResource BorderSubtleBrush}"
                    BorderThickness="0,1,0,0" Background="{StaticResource SurfaceBrush}">
                <Grid MinHeight="52">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" MinHeight="52" Margin="0,0,12,0"
                            Background="{StaticResource SurfaceElevatedBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1" CornerRadius="12">
                        <Grid>
                            <TextBox x:Name="InputBox"
                                     Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="{StaticResource TextPrimaryBrush}"
                                     CaretBrush="{StaticResource AccentBrush}"
                                     FontSize="14"
                                     Padding="16,14"
                                     MinHeight="50"
                                     VerticalContentAlignment="Center"
                                     AcceptsReturn="False">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Return" Command="{Binding SendCommand}"/>
                                </TextBox.InputBindings>
                            </TextBox>
                            <TextBlock Text="Type your question here…"
                                       IsHitTestVisible="False"
                                       Margin="18,0,0,0"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       FontSize="14">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=InputBox}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>
                    <Button Grid.Column="1" Style="{StaticResource PrimaryButton}"
                            Command="{Binding SendCommand}" IsEnabled="{Binding CanSend}"
                            Width="52" Height="52" Padding="0"
                            VerticalAlignment="Center" ToolTip="Send message">
                        <TextBlock Text="➤" FontSize="20" FontWeight="Bold"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Top bar -->
            <Border DockPanel.Dock="Top" Padding="24,16"
                    BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,0,0,1">
                <Grid>
                    <StackPanel Orientation="Horizontal">
                        <Border Width="40" Height="40" CornerRadius="12" Margin="0,0,14,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#4F8EF7" Offset="0"/>
                                    <GradientStop Color="#7C5CFC" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="✨" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="AI Chat" Style="{StaticResource H2}" Margin="0"/>
                            <TextBlock Text="Ask anything about your emails — powered by DeepSeek RAG"
                                       Style="{StaticResource Caption}"/>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Background="{StaticResource SurfaceElevatedBrush}" CornerRadius="16"
                                Padding="10,5" Margin="0,0,10,0">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ContextInfo, Converter={StaticResource StringNotEmpty}}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="{Binding ContextInfo}" Style="{StaticResource Caption}"
                                       Foreground="{StaticResource AccentBrush}"/>
                        </Border>
                        <Button Style="{StaticResource GhostButton}" Command="{Binding ClearSessionCommand}"
                                FontSize="11" Padding="12,6">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🗑" Margin="0,0,6,0"/>
                                <TextBlock Text="Clear"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Messages -->
            <ScrollViewer x:Name="MessagesScroll"
                          VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="24,20" MaxWidth="820" HorizontalAlignment="Center">

                    <!-- Empty state -->
                    <StackPanel Visibility="{Binding HasMessages, Converter={StaticResource InverseBoolToVisibility}}"
                                HorizontalAlignment="Center" Margin="0,48,0,0">
                        <Border Width="72" Height="72" CornerRadius="20" HorizontalAlignment="Center" Margin="0,0,0,20">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#334F8EF7" Offset="0"/>
                                    <GradientStop Color="#337C5CFC" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="💬" FontSize="32" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Ask me anything about your emails" Style="{StaticResource H2}"
                                   HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Style="{StaticResource Body}" HorizontalAlignment="Center" TextAlignment="Center"
                                   MaxWidth="420" Opacity="0.85">
                            Summarize threads, find attachments, track action items, or search by sender and topic.
                        </TextBlock>

                        <WrapPanel HorizontalAlignment="Center" Margin="0,28,0,0">
                            <Button Style="{StaticResource SuggestionChip}" Margin="5"
                                    Command="{Binding SuggestionCommand}"
                                    CommandParameter="Summarize today's emails"
                                    Content="📋  Today's summary"/>
                            <Button Style="{StaticResource SuggestionChip}" Margin="5"
                                    Command="{Binding SuggestionCommand}"
                                    CommandParameter="Show me all urgent or important emails"
                                    Content="🚨  Urgent emails"/>
                            <Button Style="{StaticResource SuggestionChip}" Margin="5"
                                    Command="{Binding SuggestionCommand}"
                                    CommandParameter="this week rejection summary"
                                    Content="📊  Weekly recap"/>
                            <Button Style="{StaticResource SuggestionChip}" Margin="5"
                                    Command="{Binding SuggestionCommand}"
                                    CommandParameter="Find all shipment delay discussions"
                                    Content="📦  Shipment delays"/>
                        </WrapPanel>
                    </StackPanel>

                    <!-- Message bubbles -->
                    <ItemsControl ItemsSource="{Binding Messages}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:ChatMessageItem}">
                                <Grid Margin="0,0,0,20">

                                    <!-- User -->
                                    <StackPanel HorizontalAlignment="Right" MaxWidth="520"
                                                Visibility="{Binding IsUser, Converter={StaticResource BoolToVisibility}}">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,6">
                                            <TextBlock Text="{Binding TimeText}" FontSize="10"
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Text="You" FontSize="11" FontWeight="Medium"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <Border Width="26" Height="26" CornerRadius="13"
                                                    Background="{StaticResource SurfaceElevatedBrush}">
                                                <TextBlock Text="👤" FontSize="12" HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                        </StackPanel>
                                        <Border Background="{StaticResource UserBubbleBrush}"
                                                CornerRadius="16,16,4,16" Padding="16,12">
                                            <TextBlock Text="{Binding Content}" TextWrapping="Wrap"
                                                       Foreground="White" FontSize="13.5" LineHeight="22"/>
                                        </Border>
                                    </StackPanel>

                                    <!-- Assistant -->
                                    <StackPanel HorizontalAlignment="Left" MaxWidth="760"
                                                Visibility="{Binding IsAssistant, Converter={StaticResource BoolToVisibility}}">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                            <Border Width="30" Height="30" CornerRadius="10">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#4F8EF7" Offset="0"/>
                                                        <GradientStop Color="#7C5CFC" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <TextBlock Text="✨" FontSize="14" HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Text="EmailAI" FontSize="12" FontWeight="SemiBold"
                                                       Margin="8,0,0,0" VerticalAlignment="Center"
                                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                                            <TextBlock Text="{Binding TimeText}" FontSize="10"
                                                       Margin="10,0,0,0" VerticalAlignment="Center"
                                                       Foreground="{StaticResource TextMutedBrush}"/>
                                        </StackPanel>

                                        <Border Background="{StaticResource AiBubbleBrush}"
                                                BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                                                CornerRadius="4,16,16,16" Padding="18,14">
                                            <ctrl:MarkdownTextBlock Text="{Binding Content}"/>
                                        </Border>

                                        <!-- Clickable reference emails -->
                                        <StackPanel Margin="4,10,0,0"
                                                    Visibility="{Binding HasSources, Converter={StaticResource BoolToVisibility}}">
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                <TextBlock Text="📎" FontSize="12" Margin="0,0,6,0"/>
                                                <TextBlock Text="Referenced emails — click to open"
                                                           FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                                            </StackPanel>
                                            <ItemsControl ItemsSource="{Binding SourceLinks}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate DataType="{x:Type vm:EmailSourceLink}">
                                                        <Button Style="{StaticResource EmailSourceLinkButton}"
                                                                Command="{Binding DataContext.OpenSourceEmailCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Grid.Column="0" Text="📧" FontSize="16"
                                                                           VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                                <StackPanel Grid.Column="1">
                                                                    <TextBlock Text="{Binding Subject}" FontSize="13"
                                                                               FontWeight="SemiBold" TextTrimming="CharacterEllipsis"
                                                                               Foreground="{StaticResource AccentBrush}"
                                                                               TextDecorations="Underline"/>
                                                                    <TextBlock Text="{Binding Detail}" FontSize="11"
                                                                               Margin="0,3,0,0"
                                                                               Foreground="{StaticResource TextMutedBrush}"/>
                                                                </StackPanel>
                                                                <TextBlock Grid.Column="2" Text="→" FontSize="14"
                                                                           Foreground="{StaticResource AccentBrush}"
                                                                           VerticalAlignment="Center" Margin="8,0,0,0"/>
                                                            </Grid>
                                                        </Button>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Thinking -->
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0"
                                Visibility="{Binding IsThinking, Converter={StaticResource BoolToVisibility}}">
                        <Border Width="30" Height="30" CornerRadius="10">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#4F8EF7" Offset="0"/>
                                    <GradientStop Color="#7C5CFC" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="✨" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <Border Background="{StaticResource AiBubbleBrush}" CornerRadius="4,16,16,16"
                                Padding="16,12" Margin="10,0,0,0"
                                BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Thinking" FontSize="13"
                                           Foreground="{StaticResource TextMutedBrush}"/>
                                <TextBlock Text="..." FontSize="13" Foreground="{StaticResource AccentBrush}"
                                           Margin="2,0,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </DockPanel>
    </Grid>
</UserControl>
