<UserControl x:Class="EmailAI.WPF.Views.EmailListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:EmailAI.WPF.ViewModels">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header + search bar -->
        <Border Grid.Row="0" Padding="20,14,20,14"
                BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="{Binding Title}" Style="{StaticResource H2}"/>
                    <TextBlock Text="{Binding Subtitle}" Style="{StaticResource Caption}" Margin="0,2,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <ComboBox ItemsSource="{Binding SearchModes}"
                              SelectedItem="{Binding SelectedSearchMode}"
                              Width="110" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBox Style="{StaticResource DarkTextBox}"
                             Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                             Width="280" VerticalAlignment="Center">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Return" Command="{Binding SearchCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>
                    <Button Content="Search" Style="{StaticResource PrimaryButton}"
                            Command="{Binding SearchCommand}"
                            Margin="8,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Split: email list + detail -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Email list -->
            <Border Grid.Column="0" BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Loading -->
                    <ProgressBar Grid.Row="0" IsIndeterminate="True" Height="3"
                                 Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"/>

                    <ListBox Grid.Row="1" ItemsSource="{Binding Emails}"
                             SelectedItem="{Binding SelectedEmail}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             VirtualizingPanel.IsVirtualizing="True"
                             VirtualizingPanel.VirtualizationMode="Recycling">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:EmailListItem}">
                                <Border Padding="14,12" BorderBrush="{StaticResource BorderSubtleBrush}"
                                        BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid Grid.Row="0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding SenderDisplay}" FontSize="13" FontWeight="Medium"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                <TextBlock Text="📎" FontSize="10" Margin="0,0,4,0"
                                                           Visibility="{Binding HasAttachments, Converter={StaticResource BoolToVisibility}}"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Text="⚡" FontSize="10" Margin="0,0,4,0"
                                                           Visibility="{Binding IsImportant, Converter={StaticResource BoolToVisibility}}"
                                                           VerticalAlignment="Center"
                                                           Foreground="{StaticResource WarningBrush}"/>
                                                <TextBlock Text="{Binding DateDisplay}" FontSize="11"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Grid>
                                        <TextBlock Grid.Row="1" Text="{Binding Subject}" FontSize="12"
                                                   FontWeight="{Binding SubjectWeight}"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   TextTrimming="CharacterEllipsis" Margin="0,3,0,0"/>
                                        <TextBlock Grid.Row="2" Text="{Binding Preview}" FontSize="11"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- Email detail -->
            <Grid Grid.Column="1">
                <!-- Empty state -->
                <StackPanel Visibility="{Binding HasSelectedEmail, Converter={StaticResource InverseBoolToVisibility}}"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="📧" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                    <TextBlock Text="Select an email to read" Style="{StaticResource H3}"
                               HorizontalAlignment="Center" Foreground="{StaticResource TextMutedBrush}"/>
                </StackPanel>

                <!-- Email detail panel -->
                <Grid Visibility="{Binding HasSelectedEmail, Converter={StaticResource BoolToVisibility}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Email header -->
                    <Border Grid.Row="0" Padding="20,16" Style="{StaticResource Card}" CornerRadius="0"
                            BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="{Binding SelectedEmail.Subject}" Style="{StaticResource H2}"
                                       TextWrapping="Wrap" Margin="0,0,0,8"/>
                            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,6">
                                <TextBlock Text="From: " Style="{StaticResource Caption}"/>
                                <TextBlock Text="{Binding SelectedEmail.SenderDisplay}" FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}" FontWeight="Medium"/>
                            </StackPanel>
                            <StackPanel Grid.Row="2" Orientation="Horizontal">
                                <TextBlock Text="{Binding SelectedEmail.DateFull}" Style="{StaticResource Caption}"
                                           Margin="0,0,16,0"/>
                                <TextBlock Text="{Binding SelectedEmail.FolderName}" Style="{StaticResource Caption}"
                                           Foreground="{StaticResource AccentBrush}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Attachments -->
                    <Border Grid.Row="1" Padding="20,10" Style="{StaticResource Card}" CornerRadius="0"
                            BorderThickness="0,0,0,1"
                            Visibility="{Binding HasAttachments, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel>
                            <TextBlock Text="📎 Attachments (auto-loaded)" Style="{StaticResource Caption}" Margin="0,0,0,8"/>
                            <ItemsControl ItemsSource="{Binding EmailAttachments}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:AttachmentListItem}">
                                        <Border Background="{StaticResource SurfaceElevatedBrush}"
                                                CornerRadius="6" Padding="10,8" Margin="0,0,0,6">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding StatusIcon}" FontSize="11"
                                                                   Foreground="{StaticResource SuccessBrush}"
                                                                   Margin="0,0,6,0"/>
                                                        <TextBlock Text="{Binding FileName}" FontSize="12"
                                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding SizeDisplay}" FontSize="10"
                                                               Foreground="{StaticResource TextMutedBrush}"/>
                                                </StackPanel>
                                                <Button Grid.Column="1" Content="{Binding ActionLabel}"
                                                        Style="{StaticResource GhostButton}"
                                                        Command="{Binding DataContext.ReadAttachmentCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Padding="10,4" Margin="8,0,0,0" FontSize="11"/>
                                                <Button Grid.Column="2" Content="Open"
                                                        Style="{StaticResource GhostButton}"
                                                        Command="{Binding DataContext.OpenAttachmentCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Padding="10,4" Margin="4,0,0,0" FontSize="11"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- Email body (+ auto-loaded attachment text) -->
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="20,16">
                        <TextBlock Text="{Binding DisplayBodyText}" Style="{StaticResource Body}"
                                   TextWrapping="Wrap" LineHeight="22"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                    </ScrollViewer>

                    <!-- Action bar -->
                    <Border Grid.Row="3" Padding="16,12" Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,1,0,0">
                        <Grid>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="↩ Reply" Style="{StaticResource PrimaryButton}"
                                        Command="{Binding OpenReplyCommand}" Margin="0,0,8,0"/>
                                <Button Content="🤖 AI Reply" Style="{StaticResource GhostButton}"
                                        Command="{Binding AiReplyCommand}" Margin="0,0,8,0"/>
                                <Button Content="📋 Summarize" Style="{StaticResource GhostButton}"
                                        Command="{Binding SummarizeCommand}"/>
                            </StackPanel>
                            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                                <TextBlock Text="{Binding SelectedEmail.FolderName}" Style="{StaticResource Caption}"
                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Attachment text preview -->
                    <Border Grid.Row="4" Visibility="{Binding ShowAttachmentPreview, Converter={StaticResource BoolToVisibility}}"
                            Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,1,0,0"
                            MaxHeight="360">
                        <Grid Margin="20,12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0" Margin="0,0,0,8">
                                <TextBlock Text="{Binding AttachmentPreviewTitle}" Style="{StaticResource H3}"/>
                                <Button Content="✕" HorizontalAlignment="Right" Style="{StaticResource GhostButton}"
                                        Command="{Binding CloseAttachmentPreviewCommand}" Padding="8,4"/>
                            </Grid>
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <TextBlock Text="{Binding AttachmentPreviewText}" Style="{StaticResource Body}"
                                           TextWrapping="Wrap" LineHeight="20"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>

                <!-- AI Reply panel (slide-in) -->
                <Border Visibility="{Binding ShowReplyPanel, Converter={StaticResource BoolToVisibility}}"
                        Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,1,0,0"
                        VerticalAlignment="Bottom" MaxHeight="380">
                    <Grid Margin="20,16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,12">
                            <TextBlock Text="✍️ AI Reply Generator" Style="{StaticResource H3}"/>
                            <Button Content="✕" HorizontalAlignment="Right" Style="{StaticResource GhostButton}"
                                    Command="{Binding CloseReplyCommand}" Padding="8,4"/>
                        </Grid>

                        <!-- Reply tone selector -->
                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="Tone: " Style="{StaticResource Caption}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <RadioButton Content="Professional" GroupName="Tone" Margin="0,0,10,0"
                                         IsChecked="{Binding IsProfessional}"
                                         Foreground="{StaticResource TextSecondaryBrush}"/>
                            <RadioButton Content="Friendly" GroupName="Tone" Margin="0,0,10,0"
                                         IsChecked="{Binding IsFriendly}"
                                         Foreground="{StaticResource TextSecondaryBrush}"/>
                            <RadioButton Content="Formal" GroupName="Tone" Margin="0,0,10,0"
                                         IsChecked="{Binding IsFormal}"
                                         Foreground="{StaticResource TextSecondaryBrush}"/>
                            <RadioButton Content="Short" GroupName="Tone"
                                         IsChecked="{Binding IsShort}"
                                         Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>

                        <TextBox Grid.Row="2" Style="{StaticResource DarkTextBox}"
                                 Text="{Binding ReplyText, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True" TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 MinHeight="120" MaxHeight="180"/>

                        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,10,0,0" HorizontalAlignment="Right">
                            <Button Content="🤖 Generate" Style="{StaticResource GhostButton}"
                                    Command="{Binding GenerateReplyCommand}"
                                    IsEnabled="{Binding IsGeneratingReply, Converter={StaticResource InverseBool}}"
                                    Margin="0,0,8,0"/>
                            <Button Content="📤 Send Reply" Style="{StaticResource PrimaryButton}"
                                    Command="{Binding SendReplyCommand}"
                                    IsEnabled="{Binding CanSendReply}"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
