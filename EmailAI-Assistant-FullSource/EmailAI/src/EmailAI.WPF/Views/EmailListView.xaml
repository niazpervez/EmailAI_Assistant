<UserControl x:Class="EmailAI.WPF.Views.EmailListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:EmailAI.UI.Shared.ViewModels;assembly=EmailAI.UI.Shared"
             xmlns:ctrl="clr-namespace:EmailAI.WPF.Controls">

    <Grid Background="{StaticResource PrimaryBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="360"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ── Folder sidebar ─────────────────────────────────────── -->
        <Border Grid.Column="0" Width="248"
                Background="{StaticResource NavBgBrush}"
                BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,0,1,0"
                Visibility="{Binding ShowFolderPanel, Converter={StaticResource BoolToVisibility}}">
            <DockPanel>
                <Border DockPanel.Dock="Top" Padding="16,18,16,12"
                        BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,0,0,1">
                    <StackPanel>
                        <TextBlock Text="MAILBOX" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,10"/>
                        <TextBox Style="{StaticResource DarkTextBox}"
                                 Text="{Binding FolderFilter, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="12" Padding="10,7"/>
                        <TextBlock Text="Filter folders…" FontSize="11"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   Margin="12,-28,0,0" IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding FolderFilter}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <TextBlock DockPanel.Dock="Bottom" Padding="16,10"
                           Text="{Binding FilteredFolders.Count, StringFormat={}{0} folders}"
                           FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>

                <ListBox ItemsSource="{Binding FilteredFolders}"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         VirtualizingPanel.IsVirtualizing="True"
                         VirtualizingPanel.VirtualizationMode="Recycling"
                         ItemContainerStyle="{StaticResource MailFolderListBoxItem}">
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:FolderListItem}">
                            <Button Background="Transparent" BorderThickness="0" Padding="12,10"
                                    HorizontalContentAlignment="Stretch" Cursor="Hand"
                                    Command="{Binding DataContext.SelectFolderCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Bg" Background="Transparent" CornerRadius="8"
                                                            Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bg" Property="Background" Value="#1AFFFFFF"/>
                                                        </Trigger>
                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                            <Setter TargetName="Bg" Property="Background" Value="#264F8EF7"/>
                                                        </DataTrigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Icon}" FontSize="14"
                                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="12.5"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Border Background="{StaticResource AccentBrush}" CornerRadius="8"
                                                Padding="6,2" MinWidth="22" Margin="0,0,4,0"
                                                Visibility="{Binding HasUnread, Converter={StaticResource BoolToVisibility}}">
                                            <TextBlock Text="{Binding UnreadDisplay}" FontSize="10" FontWeight="SemiBold"
                                                       Foreground="White" HorizontalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="{Binding CountDisplay}" FontSize="10"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                            </Button>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- ── Email list column ──────────────────────────────────── -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Padding="16,14"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,0,1,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="{Binding Title}" Style="{StaticResource H2}"/>
                        <TextBlock Text="{Binding Subtitle}" Style="{StaticResource Caption}" Margin="0,2,0,0"/>
                    </StackPanel>
                    <Button Grid.Column="1" Content="↻" Style="{StaticResource GhostButton}"
                            Command="{Binding RefreshMailCommand}" Padding="10,6"
                            ToolTip="Refresh" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <Border Grid.Row="1" BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,0,1,0">
                <Grid>
                    <ProgressBar VerticalAlignment="Top" IsIndeterminate="True" Height="3"
                                 Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"/>

                    <ListBox ItemsSource="{Binding Emails}"
                             SelectedItem="{Binding SelectedEmail}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             VirtualizingPanel.IsVirtualizing="True"
                             VirtualizingPanel.VirtualizationMode="Recycling"
                             ItemContainerStyle="{StaticResource MailEmailListBoxItem}">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:EmailListItem}">
                                <Border Padding="12,10" Margin="4,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <Grid Grid.Column="0" Width="36" Margin="0,0,10,0">
                                            <Ellipse Width="34" Height="34"
                                                     Fill="{StaticResource SurfaceElevatedBrush}"/>
                                            <TextBlock Text="{Binding SenderInitial}" FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{StaticResource AccentBrush}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            <Ellipse Width="8" Height="8" HorizontalAlignment="Right" VerticalAlignment="Top"
                                                     Fill="{StaticResource AccentBrush}" Margin="0,-1,-1,0"
                                                     Visibility="{Binding IsUnread, Converter={StaticResource BoolToVisibility}}"/>
                                        </Grid>

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding SenderDisplay}" FontSize="13"
                                                           FontWeight="{Binding SubjectWeight}"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                    <TextBlock Text="📎" FontSize="10" Margin="0,0,4,0"
                                                               Visibility="{Binding HasAttachments, Converter={StaticResource BoolToVisibility}}"/>
                                                    <TextBlock Text="★" FontSize="10" Foreground="{StaticResource WarningBrush}"
                                                               Visibility="{Binding IsImportant, Converter={StaticResource BoolToVisibility}}"/>
                                                </StackPanel>
                                            </Grid>
                                            <TextBlock Text="{Binding Subject}" FontSize="12"
                                                       FontWeight="{Binding SubjectWeight}"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                            <TextBlock Text="{Binding Preview}" FontSize="11"
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                        </StackPanel>

                                        <TextBlock Grid.Column="2" Text="{Binding DateDisplay}" FontSize="11"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   VerticalAlignment="Top" Margin="8,2,0,0"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>

        <!-- ── Reading pane ───────────────────────────────────────── -->
        <Grid Grid.Column="2">
            <!-- Search header (search mode only) -->
            <Border VerticalAlignment="Top" Padding="20,14"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,0,0,1"
                    Visibility="{Binding IsSearchMode, Converter={StaticResource BoolToVisibility}}">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <ComboBox ItemsSource="{Binding SearchModes}"
                              SelectedItem="{Binding SelectedSearchMode}"
                              Width="110" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBox Style="{StaticResource DarkTextBox}"
                             Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                             Width="300" VerticalAlignment="Center">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Return" Command="{Binding SearchCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>
                    <Button Content="Search" Style="{StaticResource PrimaryButton}"
                            Command="{Binding SearchCommand}"
                            Margin="8,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Empty state -->
            <StackPanel Visibility="{Binding HasSelectedEmail, Converter={StaticResource InverseBoolToVisibility}}"
                        HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border Background="{StaticResource SurfaceElevatedBrush}" CornerRadius="16"
                        Width="72" Height="72" Margin="0,0,0,16">
                    <TextBlock Text="✉" FontSize="32" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="Select an email to read" Style="{StaticResource H3}"
                           HorizontalAlignment="Center" Foreground="{StaticResource TextMutedBrush}"/>
                <TextBlock Text="Choose a folder on the left, then pick a message"
                           Style="{StaticResource Caption}" HorizontalAlignment="Center" Margin="0,6,0,0"/>
            </StackPanel>

            <!-- Detail -->
            <Grid Visibility="{Binding HasSelectedEmail, Converter={StaticResource BoolToVisibility}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Padding="24,20" Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,0,0,1">
                    <StackPanel>
                        <TextBlock Text="{Binding SelectedEmail.Subject}" Style="{StaticResource H2}"
                                   TextWrapping="Wrap" Margin="0,0,0,12"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="40" Height="40" CornerRadius="20"
                                    Background="{StaticResource ChatAccentSoftBrush}" Margin="0,0,12,0">
                                <TextBlock Text="{Binding SelectedEmail.SenderInitial}" FontSize="15" FontWeight="SemiBold"
                                           Foreground="{StaticResource AccentBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding SelectedEmail.SenderDisplay}" FontSize="13" FontWeight="Medium"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <TextBlock Text="{Binding SelectedEmail.DateFull}" Style="{StaticResource Caption}"/>
                                    <Border Background="{StaticResource ChatAccentSoftBrush}" CornerRadius="4"
                                            Padding="8,2" Margin="12,0,0,0">
                                        <TextBlock Text="{Binding SelectedEmail.FolderName}" FontSize="11"
                                                   Foreground="{StaticResource AccentBrush}"/>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Padding="24,12" Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,0,0,1"
                        Visibility="{Binding HasAttachments, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel>
                        <TextBlock Text="Attachments" Style="{StaticResource Caption}" Margin="0,0,0,8"/>
                        <ItemsControl ItemsSource="{Binding EmailAttachments}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:AttachmentListItem}">
                                    <Border Background="{StaticResource SurfaceElevatedBrush}"
                                            CornerRadius="8" Padding="12,10" Margin="0,0,0,6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding StatusIcon}" FontSize="11"
                                                               Foreground="{StaticResource SuccessBrush}" Margin="0,0,6,0"/>
                                                    <TextBlock Text="{Binding FileName}" FontSize="12"
                                                               Foreground="{StaticResource TextPrimaryBrush}"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                                <TextBlock Text="{Binding SizeDisplay}" FontSize="10"
                                                           Foreground="{StaticResource TextMutedBrush}"/>
                                            </StackPanel>
                                            <Button Grid.Column="1" Content="{Binding ActionLabel}"
                                                    Style="{StaticResource GhostButton}"
                                                    Command="{Binding DataContext.ReadAttachmentCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Padding="10,4" Margin="8,0,0,0" FontSize="11"/>
                                            <Button Grid.Column="2" Content="Open"
                                                    Style="{StaticResource GhostButton}"
                                                    Command="{Binding DataContext.OpenAttachmentCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Padding="10,4" Margin="4,0,0,0" FontSize="11"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="24,20">
                    <ctrl:MarkdownTextBlock Text="{Binding DisplayBodyText}"/>
                </ScrollViewer>

                <Border Grid.Row="3" Padding="20,14" Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,1,0,0">
                    <StackPanel Orientation="Horizontal">
                        <Button Content="↩ Reply" Style="{StaticResource PrimaryButton}"
                                Command="{Binding OpenReplyCommand}" Margin="0,0,8,0"/>
                        <Button Content="🤖 AI Reply" Style="{StaticResource GhostButton}"
                                Command="{Binding AiReplyCommand}" Margin="0,0,8,0"/>
                        <Button Content="📋 Summarize" Style="{StaticResource GhostButton}"
                                Command="{Binding SummarizeCommand}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="4" Visibility="{Binding ShowAttachmentPreview, Converter={StaticResource BoolToVisibility}}"
                        Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,1,0,0"
                        MaxHeight="320">
                    <Grid Margin="24,12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Margin="0,0,0,8">
                            <TextBlock Text="{Binding AttachmentPreviewTitle}" Style="{StaticResource H3}"/>
                            <Button Content="✕" HorizontalAlignment="Right" Style="{StaticResource GhostButton}"
                                    Command="{Binding CloseAttachmentPreviewCommand}" Padding="8,4"/>
                        </Grid>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ctrl:MarkdownTextBlock Text="{Binding AttachmentPreviewText}"/>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>

            <!-- Reply panel -->
            <Border Visibility="{Binding ShowReplyPanel, Converter={StaticResource BoolToVisibility}}"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,1,0,0"
                    VerticalAlignment="Bottom" MaxHeight="380">
                <Grid Margin="24,16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <TextBlock Text="AI Reply Generator" Style="{StaticResource H3}"/>
                        <Button Content="✕" HorizontalAlignment="Right" Style="{StaticResource GhostButton}"
                                Command="{Binding CloseReplyCommand}" Padding="8,4"/>
                    </Grid>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Tone:" Style="{StaticResource Caption}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <RadioButton Content="Professional" GroupName="Tone" Margin="0,0,10,0"
                                     IsChecked="{Binding IsProfessional}"
                                     Foreground="{StaticResource TextSecondaryBrush}"/>
                        <RadioButton Content="Friendly" GroupName="Tone" Margin="0,0,10,0"
                                     IsChecked="{Binding IsFriendly}"
                                     Foreground="{StaticResource TextSecondaryBrush}"/>
                        <RadioButton Content="Formal" GroupName="Tone" Margin="0,0,10,0"
                                     IsChecked="{Binding IsFormal}"
                                     Foreground="{StaticResource TextSecondaryBrush}"/>
                        <RadioButton Content="Short" GroupName="Tone"
                                     IsChecked="{Binding IsShort}"
                                     Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>

                    <TextBox Grid.Row="2" Style="{StaticResource DarkTextBox}"
                             Text="{Binding ReplyText, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True" TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             MinHeight="120" MaxHeight="180"/>

                    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,10,0,0" HorizontalAlignment="Right">
                        <Button Content="Generate" Style="{StaticResource GhostButton}"
                                Command="{Binding GenerateReplyCommand}"
                                IsEnabled="{Binding IsGeneratingReply, Converter={StaticResource InverseBool}}"
                                Margin="0,0,8,0"/>
                        <Button Content="Send Reply" Style="{StaticResource PrimaryButton}"
                                Command="{Binding SendReplyCommand}"
                                IsEnabled="{Binding CanSendReply}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
