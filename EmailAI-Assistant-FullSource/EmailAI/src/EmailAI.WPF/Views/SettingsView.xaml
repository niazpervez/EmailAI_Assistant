<UserControl x:Class="EmailAI.WPF.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,24,28,24" MaxWidth="680">

            <TextBlock Text="Settings" Style="{StaticResource H1}" Margin="0,0,0,4"/>
            <TextBlock Text="Configure your EmailAI Assistant" Style="{StaticResource Body}" Margin="0,0,0,24"/>

            <!-- OAuth (browser sign-in for Gmail / Outlook) -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="🔐 OAuth Setup (Gmail &amp; Microsoft)" Style="{StaticResource H3}" Margin="0,0,0,8"/>
                    <TextBlock Style="{StaticResource Body}" TextWrapping="Wrap" Margin="0,0,0,12">
                        Required for "Sign in with Google/Microsoft" on the Sync page. Free one-time setup:
                        Google Cloud Console → OAuth Desktop client (redirect: http://127.0.0.1:7890/)
                        · Azure Portal → App registration → Mobile/desktop → redirect: http://localhost
                    </TextBlock>
                    <TextBlock Text="Google Client ID" Style="{StaticResource Caption}" Margin="0,0,0,6"/>
                    <TextBox Style="{StaticResource DarkTextBox}" Text="{Binding GoogleOAuthClientId}" Margin="0,0,0,8"/>
                    <TextBlock Text="Google Client Secret (optional for desktop)" Style="{StaticResource Caption}" Margin="0,0,0,6"/>
                    <TextBox Style="{StaticResource DarkTextBox}" Text="{Binding GoogleOAuthClientSecret}" Margin="0,0,0,12"/>
                    <TextBlock Text="Microsoft Client ID" Style="{StaticResource Caption}" Margin="0,0,0,6"/>
                    <TextBox Style="{StaticResource DarkTextBox}" Text="{Binding MicrosoftOAuthClientId}"/>
                </StackPanel>
            </Border>

            <!-- DeepSeek API -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="🤖 DeepSeek AI" Style="{StaticResource H3}"/>
                        <Border Background="{StaticResource AccentBrush}" CornerRadius="4" Padding="6,2" Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Required" FontSize="10" Foreground="White" FontWeight="Medium"/>
                        </Border>
                    </StackPanel>
                    <TextBlock Style="{StaticResource Body}" Margin="0,0,0,14">
                        Enter your DeepSeek API key. Get one at
                        <Hyperlink NavigateUri="https://platform.deepseek.com">platform.deepseek.com</Hyperlink>.
                        The key is stored encrypted using Windows DPAPI.
                    </TextBlock>

                    <TextBlock Text="API Key" Style="{StaticResource Caption}" Margin="0,0,0,6"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <PasswordBox x:Name="ApiKeyBox" Height="38" Padding="10,0"
                                     Background="{StaticResource SurfaceElevatedBrush}"
                                     Foreground="{StaticResource TextPrimaryBrush}"
                                     BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                     PasswordChar="●"/>
                        <Button Grid.Column="1" Content="Save" Style="{StaticResource PrimaryButton}"
                                Click="SaveApiKey_Click" Margin="8,0,0,0" Padding="16,8"/>
                    </Grid>
                    <TextBlock Text="{Binding ApiKeyStatus}" Margin="0,6,0,0" FontSize="12"
                               Foreground="{Binding ApiKeyStatusColor, Converter={StaticResource HexToBrush}}"/>

                    <Separator Margin="0,12"/>

                    <TextBlock Text="Model" Style="{StaticResource Caption}" Margin="0,0,0,6"/>
                    <ComboBox ItemsSource="{Binding AvailableModels}"
                              SelectedItem="{Binding SelectedModel}"
                              Width="250" HorizontalAlignment="Left"/>
                </StackPanel>
            </Border>

            <!-- Sync Settings -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="🔄 Synchronization" Style="{StaticResource H3}" Margin="0,0,0,14"/>

                    <TextBlock Text="Auto-sync interval" Style="{StaticResource Caption}" Margin="0,0,0,6"/>
                    <ComboBox ItemsSource="{Binding SyncIntervals}"
                              SelectedItem="{Binding SelectedInterval}"
                              Width="200" HorizontalAlignment="Left"/>

                    <TextBlock Text="Default sync period" Style="{StaticResource Caption}" Margin="0,12,0,6"/>
                    <ComboBox ItemsSource="{Binding AvailableSyncPeriods}"
                              SelectedItem="{Binding SelectedSyncPeriod}"
                              Width="220" HorizontalAlignment="Left"/>
                    <TextBlock Text="Used for manual and automatic sync — limits how far back emails are downloaded."
                               Style="{StaticResource Caption}" Foreground="{StaticResource TextMutedBrush}"
                               TextWrapping="Wrap" Margin="0,6,0,0"/>

                    <Separator Margin="0,12"/>
                    <CheckBox Content="Sync all folders on my mailbox (Inbox, Sent, and all custom folders)"
                              IsChecked="{Binding SyncAllFolders}"
                              Foreground="{StaticResource TextSecondaryBrush}"
                              Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding FolderListHint}"
                               Style="{StaticResource Caption}" Foreground="{StaticResource TextMutedBrush}"
                               TextWrapping="Wrap" Margin="0,0,0,8"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Folders to sync" Style="{StaticResource Caption}" VerticalAlignment="Center"/>
                        <Button Content="Refresh from mailbox" Style="{StaticResource GhostButton}"
                                Command="{Binding RefreshFoldersCommand}"
                                Margin="12,0,0,0" Padding="10,4" FontSize="11"/>
                    </StackPanel>
                    <ItemsControl ItemsSource="{Binding FolderOptions}" IsEnabled="{Binding FolderListEnabled}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <CheckBox Content="{Binding Name}" IsChecked="{Binding IsSelected}"
                                          Foreground="{StaticResource TextSecondaryBrush}"
                                          Margin="0,4"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Data Storage -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="💾 Data Storage" Style="{StaticResource H3}" Margin="0,0,0,14"/>

                    <TextBlock Text="Database location" Style="{StaticResource Caption}" Margin="0,0,0,6"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Style="{StaticResource DarkTextBox}" Text="{Binding DatabasePath}"
                                 IsReadOnly="True" Foreground="{StaticResource TextMutedBrush}"/>
                        <Button Grid.Column="1" Content="Browse" Style="{StaticResource GhostButton}"
                                Command="{Binding BrowseDbCommand}" Margin="8,0,0,0"/>
                    </Grid>

                    <Separator Margin="0,12"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="🗑 Clear All Data" Style="{StaticResource GhostButton}"
                                Command="{Binding ClearDataCommand}"
                                Foreground="{StaticResource DangerBrush}" Margin="0,0,8,0"/>
                        <TextBlock Text="This will delete all synced emails and embeddings."
                                   Style="{StaticResource Caption}" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- About -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="ℹ️ About" Style="{StaticResource H3}" Margin="0,0,0,14"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Version" Style="{StaticResource Caption}"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="1.0.0" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Framework" Style="{StaticResource Caption}" Margin="0,6,0,0"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text=".NET 9 / WPF" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,6,0,0"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="AI Provider" Style="{StaticResource Caption}" Margin="0,6,0,0"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="DeepSeek API" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,6,0,0"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Storage" Style="{StaticResource Caption}" Margin="0,6,0,0"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="SQLite + sqlite-vec (local)" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,6,0,0"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Save button -->
            <Button Content="💾 Save Settings" Style="{StaticResource PrimaryButton}"
                    Command="{Binding SaveCommand}"
                    HorizontalAlignment="Left" Margin="0,16,0,0" Padding="20,10" FontSize="14"/>

            <TextBlock Text="{Binding SaveStatus}" Margin="0,8,0,0" FontSize="12"
                       Foreground="{Binding SaveStatusColor, Converter={StaticResource HexToBrush}}"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
