<UserControl x:Class="EmailAI.WPF.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,24,28,24">

            <!-- Header -->
            <TextBlock Text="Dashboard" Style="{StaticResource H1}" Margin="0,0,0,4"/>
            <TextBlock Text="{Binding SubtitleText}" Style="{StaticResource Body}" Margin="0,0,0,24"/>

            <!-- Stat Cards Row -->
            <UniformGrid Rows="1" Columns="4" Margin="0,0,0,20">

                <Border Style="{StaticResource Card}" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="📧" FontSize="22" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding TotalEmails}" FontSize="32" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="Total Emails" Style="{StaticResource Caption}" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}" Margin="5,0,5,0">
                    <StackPanel>
                        <TextBlock Text="🔵" FontSize="22" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding UnreadEmails}" FontSize="32" FontWeight="Bold"
                                   Foreground="{StaticResource AccentBrush}"/>
                        <TextBlock Text="Unread" Style="{StaticResource Caption}" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}" Margin="5,0,5,0">
                    <StackPanel>
                        <TextBlock Text="📅" FontSize="22" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding TodayEmails}" FontSize="32" FontWeight="Bold"
                                   Foreground="{StaticResource SuccessBrush}"/>
                        <TextBlock Text="Today" Style="{StaticResource Caption}" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}" Margin="10,0,0,0">
                    <StackPanel>
                        <TextBlock Text="🧠" FontSize="22" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding IndexedEmbeddings}" FontSize="32" FontWeight="Bold"
                                   Foreground="{StaticResource WarningBrush}"/>
                        <TextBlock Text="AI Indexed" Style="{StaticResource Caption}" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Main Content: Action Items + Top Senders -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="280"/>
                </Grid.ColumnDefinitions>

                <!-- Action Items -->
                <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,12,0">
                    <StackPanel>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="⚡ AI Action Items" Style="{StaticResource H3}"/>
                            <Button Grid.Column="1" Content="Refresh" Style="{StaticResource GhostButton}"
                                    Command="{Binding RefreshActionItemsCommand}"
                                    FontSize="11" Padding="10,5"/>
                        </Grid>

                        <!-- Loading state -->
                        <StackPanel Visibility="{Binding IsLoadingActions, Converter={StaticResource BoolToVisibility}}">
                            <ProgressBar IsIndeterminate="True" Height="3" Margin="0,8"/>
                            <TextBlock Text="Analyzing emails with AI…" Style="{StaticResource Caption}"
                                       HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        </StackPanel>

                        <!-- Content -->
                        <TextBlock Text="{Binding ActionItems}"
                                   Visibility="{Binding IsLoadingActions, Converter={StaticResource InverseBoolToVisibility}}"
                                   Style="{StaticResource Body}"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextWrapping="Wrap" LineHeight="22"/>
                    </StackPanel>
                </Border>

                <!-- Top Senders -->
                <Border Grid.Column="1" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="👥 Top Senders" Style="{StaticResource H3}" Margin="0,0,0,14"/>
                        <ItemsControl ItemsSource="{Binding TopSenders}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Width="30" Height="30" CornerRadius="15"
                                                Background="{StaticResource SurfaceElevatedBrush}">
                                            <TextBlock Text="{Binding Initial}" FontSize="12" FontWeight="Bold"
                                                       Foreground="{StaticResource AccentBrush}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding DisplayName}" FontSize="12"
                                                       TextTrimming="CharacterEllipsis"
                                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                                            <TextBlock Text="{Binding Email}" FontSize="10"
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                        <Border Grid.Column="2" Style="{StaticResource UnreadBadge}"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Count}" FontSize="10" FontWeight="Bold"
                                                       Foreground="White" HorizontalAlignment="Center"/>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Quick Summary Buttons -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="📊 Quick Summaries" Style="{StaticResource H3}" Margin="0,0,0,14"/>
                    <WrapPanel>
                        <Button Content="📅 Daily Summary" Style="{StaticResource GhostButton}"
                                Command="{Binding DailySummaryCommand}" Margin="0,0,8,8"/>
                        <Button Content="📆 Weekly Summary" Style="{StaticResource GhostButton}"
                                Command="{Binding WeeklySummaryCommand}" Margin="0,0,8,8"/>
                        <Button Content="💬 Open AI Chat" Style="{StaticResource PrimaryButton}"
                                Command="{Binding OpenChatCommand}" Margin="0,0,8,8"/>
                    </WrapPanel>

                    <!-- Summary output -->
                    <Border Visibility="{Binding HasSummary, Converter={StaticResource BoolToVisibility}}"
                            Background="{StaticResource SurfaceElevatedBrush}"
                            CornerRadius="8" Padding="14" Margin="0,12,0,0">
                        <StackPanel>
                            <TextBlock Text="{Binding SummaryTitle}" Style="{StaticResource H3}" Margin="0,0,0,8"/>
                            <ScrollViewer MaxHeight="250" VerticalScrollBarVisibility="Auto">
                                <TextBlock Text="{Binding SummaryText}" Style="{StaticResource Body}"
                                           TextWrapping="Wrap" LineHeight="20"/>
                            </ScrollViewer>
                        </StackPanel>
                    </Border>

                    <!-- Summary loading -->
                    <StackPanel Visibility="{Binding IsLoadingSummary, Converter={StaticResource BoolToVisibility}}"
                                Margin="0,12,0,0">
                        <ProgressBar IsIndeterminate="True" Height="3"/>
                        <TextBlock Text="Generating summary with AI…" Style="{StaticResource Caption}"
                                   HorizontalAlignment="Center" Margin="0,8,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
