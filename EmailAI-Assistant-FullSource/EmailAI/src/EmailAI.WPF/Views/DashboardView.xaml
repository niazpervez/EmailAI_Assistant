<UserControl x:Class="EmailAI.WPF.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:EmailAI.UI.Shared.ViewModels;assembly=EmailAI.UI.Shared"
             xmlns:ctrl="clr-namespace:EmailAI.WPF.Controls">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="{StaticResource PrimaryBrush}">
        <StackPanel Margin="32,28,32,32">

            <!-- Header -->
            <Grid Margin="0,0,0,28">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Dashboard" Style="{StaticResource H1}" Margin="0,0,0,6"/>
                    <TextBlock Text="{Binding SubtitleText}" Style="{StaticResource Body}" Margin="0,0,0,6"/>
                    <StackPanel Orientation="Horizontal">
                        <Border Background="{StaticResource SurfaceElevatedBrush}" CornerRadius="6"
                                Padding="10,5" Margin="0,0,8,0">
                            <TextBlock Text="{Binding DateDisplay}" FontSize="11"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                        </Border>
                        <Border Background="{StaticResource ChatAccentSoftBrush}" CornerRadius="6" Padding="10,5">
                            <TextBlock Text="{Binding LastSyncDisplay}" FontSize="11"
                                       Foreground="{StaticResource AccentBrush}"/>
                        </Border>
                    </StackPanel>
                </StackPanel>
                <Button Grid.Column="1" Content="↻ Refresh" Style="{StaticResource GhostButton}"
                        Command="{Binding RefreshDashboardCommand}" VerticalAlignment="Top"
                        Padding="14,8"/>
            </Grid>

            <!-- KPI Cards -->
            <ItemsControl ItemsSource="{Binding KpiCards}" Margin="0,0,0,24">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="4"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:DashboardKpiItem}">
                        <Border Style="{StaticResource KpiCard}" Margin="0,0,12,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Height="3" CornerRadius="2"
                                        Background="{Binding AccentColor, Converter={StaticResource HexToBrush}}" Margin="0,0,0,16"/>

                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Label}" FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   Margin="0,0,0,8"/>
                                        <TextBlock Text="{Binding Value}" FontSize="34" FontWeight="Bold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   Margin="0,0,0,4"/>
                                        <TextBlock Text="{Binding Subtitle}" FontSize="11"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   TextWrapping="Wrap"/>
                                        <ProgressBar Style="{StaticResource KpiProgressBar}"
                                                     Value="{Binding ProgressPercent, Mode=OneWay}"
                                                     Visibility="{Binding ShowProgress, Converter={StaticResource BoolToVisibility}}"
                                                     Margin="0,14,8,0"/>
                                    </StackPanel>

                                    <Border Grid.Column="1" Width="52" Height="52" CornerRadius="26"
                                            Background="{Binding AccentSoftColor, Converter={StaticResource HexToBrush}}"
                                            VerticalAlignment="Top">
                                        <TextBlock Text="{Binding Icon}" FontSize="22"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Main grid: Action items + sidebar -->
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="300"/>
                </Grid.ColumnDefinitions>

                <!-- AI Action Items -->
                <Border Grid.Column="0" Style="{StaticResource DashboardPanel}" Margin="0,0,16,0">
                    <StackPanel>
                        <Grid Margin="0,0,0,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="32" Height="32" CornerRadius="8"
                                        Background="{StaticResource ChatAccentSoftBrush}" Margin="0,0,10,0">
                                    <TextBlock Text="⚡" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="AI Action Items" Style="{StaticResource H2}" FontSize="16"/>
                                    <TextBlock Text="From inbox today + sent follow-ups awaiting reply" Style="{StaticResource Caption}"/>
                                </StackPanel>
                            </StackPanel>
                            <Button Grid.Column="1" Content="Refresh" Style="{StaticResource GhostButton}"
                                    Command="{Binding RefreshActionItemsCommand}"
                                    FontSize="11" Padding="12,6" VerticalAlignment="Center"/>
                        </Grid>

                        <StackPanel Visibility="{Binding IsLoadingActions, Converter={StaticResource BoolToVisibility}}">
                            <ProgressBar IsIndeterminate="True" Height="3" Margin="0,8"/>
                            <TextBlock Text="Analyzing emails with AI…" Style="{StaticResource Caption}"
                                       HorizontalAlignment="Center" Margin="0,12,0,0"/>
                        </StackPanel>

                        <ItemsControl ItemsSource="{Binding ActionItemCards}"
                                      Visibility="{Binding IsLoadingActions, Converter={StaticResource InverseBoolToVisibility}}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:ActionItemCard}">
                                    <Border Style="{StaticResource ActionItemCard}" Margin="0,0,0,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Width="28" Height="28" CornerRadius="14"
                                                    Background="{StaticResource AccentBrush}" Margin="0,0,14,0">
                                                <TextBlock Text="{Binding Index}" FontSize="12" FontWeight="Bold"
                                                           Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{Binding Action}" FontSize="13" TextWrapping="Wrap"
                                                           Foreground="{StaticResource TextPrimaryBrush}" LineHeight="20"/>
                                                <WrapPanel Margin="0,8,0,0">
                                                    <Border Background="{StaticResource SurfaceElevatedBrush}"
                                                            CornerRadius="6" Padding="8,4" Margin="0,0,8,4"
                                                            Visibility="{Binding HasResponsible, Converter={StaticResource BoolToVisibility}}">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="Owner" FontSize="10"
                                                                       Foreground="{StaticResource TextMutedBrush}" Margin="0,0,6,0"/>
                                                            <TextBlock Text="{Binding Responsible}" FontSize="11"
                                                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                                                        </StackPanel>
                                                    </Border>
                                                    <Border Background="{StaticResource SurfaceElevatedBrush}"
                                                            CornerRadius="6" Padding="8,4" Margin="0,0,8,4"
                                                            Visibility="{Binding HasDeadline, Converter={StaticResource BoolToVisibility}}">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="Due" FontSize="10"
                                                                       Foreground="{StaticResource TextMutedBrush}" Margin="0,0,6,0"/>
                                                            <TextBlock Text="{Binding Deadline}" FontSize="11"
                                                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                                                        </StackPanel>
                                                    </Border>
                                                </WrapPanel>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="{Binding ActionItems}"
                                   Visibility="{Binding HasActionItems, Converter={StaticResource InverseBoolToVisibility}}"
                                   Style="{StaticResource Body}"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   TextWrapping="Wrap" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Sidebar -->
                <StackPanel Grid.Column="1">
                    <!-- Top Senders -->
                    <Border Style="{StaticResource DashboardPanel}" Margin="0,0,0,16">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <Border Width="32" Height="32" CornerRadius="8"
                                        Background="#263ECF8E" Margin="0,0,10,0">
                                    <TextBlock Text="👥" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Top Senders" Style="{StaticResource H2}" FontSize="16"/>
                                    <TextBlock Text="Most active in Inbox" Style="{StaticResource Caption}"/>
                                </StackPanel>
                            </StackPanel>

                            <ItemsControl ItemsSource="{Binding TopSenders}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:SenderItem}">
                                        <Grid Margin="0,0,0,14">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Width="36" Height="36" CornerRadius="18"
                                                    Background="{StaticResource SurfaceElevatedBrush}">
                                                <TextBlock Text="{Binding Initial}" FontSize="13" FontWeight="SemiBold"
                                                           Foreground="{StaticResource AccentBrush}"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" Margin="10,0,8,0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding DisplayName}" FontSize="12" FontWeight="Medium"
                                                           TextTrimming="CharacterEllipsis"
                                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                                <TextBlock Text="{Binding Email}" FontSize="10"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           TextTrimming="CharacterEllipsis" Margin="0,2,0,6"/>
                                                <Border Height="4" CornerRadius="2"
                                                        Background="{StaticResource SurfaceElevatedBrush}">
                                                    <Border Height="4" Width="120" CornerRadius="2"
                                                            HorizontalAlignment="Left"
                                                            Background="{StaticResource AccentBrush}"
                                                            RenderTransformOrigin="0,0.5">
                                                        <Border.RenderTransform>
                                                            <ScaleTransform ScaleX="{Binding BarFraction}" ScaleY="1"/>
                                                        </Border.RenderTransform>
                                                    </Border>
                                                </Border>
                                            </StackPanel>
                                            <Border Grid.Column="2" Style="{StaticResource UnreadBadge}"
                                                    VerticalAlignment="Top" Margin="0,4,0,0">
                                                <TextBlock Text="{Binding Count}" FontSize="10" FontWeight="Bold"
                                                           Foreground="White" HorizontalAlignment="Center"/>
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- Sent follow-ups -->
                    <Border Style="{StaticResource DashboardPanel}" Margin="0,0,0,16">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <Border Width="32" Height="32" CornerRadius="8"
                                        Background="#26F5A623" Margin="0,0,10,0">
                                    <TextBlock Text="📤" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Sent Follow-ups" Style="{StaticResource H2}" FontSize="16"/>
                                    <TextBlock Text="Reminders &amp; replies from Sent folder" Style="{StaticResource Caption}"/>
                                </StackPanel>
                            </StackPanel>

                            <ItemsControl ItemsSource="{Binding FollowUpCards}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:FollowUpCard}">
                                        <Border Background="{StaticResource SurfaceElevatedBrush}"
                                                CornerRadius="8" Padding="10" Margin="0,0,0,8">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Subject}" FontSize="12" FontWeight="Medium"
                                                           TextTrimming="CharacterEllipsis"
                                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                                <TextBlock Text="{Binding Recipient, StringFormat=To: {0}}" FontSize="10"
                                                           Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,0"/>
                                                <TextBlock Text="{Binding SentDateText}" FontSize="10"
                                                           Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,4"/>
                                                <Border CornerRadius="4" Padding="6,3" HorizontalAlignment="Left"
                                                        Background="{StaticResource ChatAccentSoftBrush}">
                                                    <TextBlock Text="{Binding StatusLabel}" FontSize="10"
                                                               Foreground="{StaticResource AccentBrush}"/>
                                                </Border>
                                                <TextBlock Text="{Binding ReplyDetail}" FontSize="10"
                                                           TextWrapping="Wrap" Margin="0,6,0,0"
                                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Text="No sent follow-ups in the last 14 days."
                                       Visibility="{Binding HasFollowUpItems, Converter={StaticResource InverseBoolToVisibility}}"
                                       Style="{StaticResource Caption}"
                                       Foreground="{StaticResource TextMutedBrush}"/>
                        </StackPanel>
                    </Border>

                    <!-- Quick actions -->
                    <Border Style="{StaticResource DashboardPanel}">
                        <StackPanel>
                            <TextBlock Text="Quick Actions" Style="{StaticResource H2}" FontSize="16" Margin="0,0,0,14"/>
                            <Button Style="{StaticResource DashboardActionTile}" Margin="0,0,0,8"
                                    Command="{Binding DailySummaryCommand}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Width="36" Height="36" CornerRadius="10"
                                            Background="{StaticResource ChatAccentSoftBrush}" Margin="0,0,12,0">
                                        <TextBlock Text="📅" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Daily Summary" FontSize="13" FontWeight="Medium"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="AI digest of today's mail" Style="{StaticResource Caption}"/>
                                    </StackPanel>
                                </Grid>
                            </Button>
                            <Button Style="{StaticResource DashboardActionTile}" Margin="0,0,0,8"
                                    Command="{Binding WeeklySummaryCommand}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Width="36" Height="36" CornerRadius="10"
                                            Background="#263ECF8E" Margin="0,0,12,0">
                                        <TextBlock Text="📆" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Weekly Summary" FontSize="13" FontWeight="Medium"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="Trends from the past 7 days" Style="{StaticResource Caption}"/>
                                    </StackPanel>
                                </Grid>
                            </Button>
                            <Button Style="{StaticResource DashboardActionTilePrimary}"
                                    Command="{Binding OpenChatCommand}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Width="36" Height="36" CornerRadius="10"
                                            Background="#33FFFFFF" Margin="0,0,12,0">
                                        <TextBlock Text="💬" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Open AI Chat" FontSize="13" FontWeight="Medium" Foreground="White"/>
                                        <TextBlock Text="Ask questions about your mail" FontSize="11" Foreground="#CCFFFFFF"/>
                                    </StackPanel>
                                </Grid>
                            </Button>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- Summary output -->
            <Border Style="{StaticResource DashboardPanel}"
                    Visibility="{Binding HasSummary, Converter={StaticResource BoolToVisibility}}">
                <StackPanel>
                    <TextBlock Text="{Binding SummaryTitle}" Style="{StaticResource H2}" FontSize="16" Margin="0,0,0,12"/>
                    <ScrollViewer MaxHeight="320" VerticalScrollBarVisibility="Auto">
                        <ctrl:MarkdownTextBlock Text="{Binding SummaryText}"/>
                    </ScrollViewer>
                </StackPanel>
            </Border>

            <StackPanel Visibility="{Binding IsLoadingSummary, Converter={StaticResource BoolToVisibility}}"
                        Margin="0,8,0,0">
                <ProgressBar IsIndeterminate="True" Height="3"/>
                <TextBlock Text="Generating summary with AI…" Style="{StaticResource Caption}"
                           HorizontalAlignment="Center" Margin="0,10,0,0"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
