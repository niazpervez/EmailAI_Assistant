<UserControl x:Class="EmailAI.WPF.Views.SyncView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,24,28,24" MaxWidth="760">

            <TextBlock Text="Email Sync" Style="{StaticResource H1}" Margin="0,0,0,4"/>
            <TextBlock Text="Connect any email provider via IMAP — or import settings from Outlook / Thunderbird"
                       Style="{StaticResource Body}" Margin="0,0,0,24"/>

            <!-- Import from Outlook / Thunderbird -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,16"
                    Visibility="{Binding ShowImportSection, Converter={StaticResource BoolToVisibility}}">
                <StackPanel>
                    <Grid Margin="0,0,0,10">
                        <TextBlock Text="Import from existing mail client" Style="{StaticResource H3}"/>
                        <Button Content="↻ Scan again" HorizontalAlignment="Right"
                                Style="{StaticResource GhostButton}"
                                Command="{Binding ScanAccountsCommand}"
                                IsEnabled="{Binding IsScanningAccounts, Converter={StaticResource InverseBool}}"
                                FontSize="11" Padding="10,4"/>
                    </Grid>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Style="{StaticResource Caption}" Margin="0,0,16,0"
                                   Visibility="{Binding OutlookDetected, Converter={StaticResource BoolToVisibility}}">
                            <Run Text="✓ " Foreground="{StaticResource SuccessBrush}"/>
                            <Run Text="Microsoft Outlook detected"/>
                        </TextBlock>
                        <TextBlock Style="{StaticResource Caption}"
                                   Visibility="{Binding ThunderbirdDetected, Converter={StaticResource BoolToVisibility}}">
                            <Run Text="✓ " Foreground="{StaticResource SuccessBrush}"/>
                            <Run Text="Mozilla Thunderbird detected"/>
                        </TextBlock>
                    </StackPanel>

                    <TextBlock Text="{Binding ImportStatusText}" Style="{StaticResource Body}"
                               TextWrapping="Wrap" Margin="0,0,0,10"
                               Foreground="{StaticResource TextSecondaryBrush}"/>

                    <ListBox ItemsSource="{Binding DiscoveredAccounts}"
                             SelectedItem="{Binding SelectedDiscoveredAccount}"
                             MaxHeight="140" Margin="0,0,0,10"
                             Background="{StaticResource SurfaceElevatedBrush}"
                             BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="4,2">
                                    <TextBlock FontSize="13" FontWeight="Medium"
                                               Foreground="{StaticResource TextPrimaryBrush}">
                                        <Run Text="{Binding SourceLabel, Mode=OneWay}"/>
                                        <Run Text=" — "/>
                                        <Run Text="{Binding Email, Mode=OneWay}"/>
                                    </TextBlock>
                                    <TextBlock Text="{Binding Summary}" Style="{StaticResource Caption}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="Use selected account" Style="{StaticResource PrimaryButton}"
                                Command="{Binding UseDiscoveredAccountCommand}"
                                Padding="14,8" Margin="0,0,12,0"/>
                        <CheckBox Content="Start sync for all folders after connect"
                                  IsChecked="{Binding StartSyncAfterImport}"
                                  VerticalAlignment="Center"
                                  Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>

                    <TextBlock Text="{Binding FolderPreviewText}" Style="{StaticResource Caption}"
                               TextWrapping="Wrap" Foreground="{StaticResource AccentBrush}"
                               Margin="0,0,0,4"/>

                    <TextBlock Style="{StaticResource Caption}" Foreground="{StaticResource TextMutedBrush}"
                               TextWrapping="Wrap">
                        We read server settings only (not passwords). After connect, every folder on your mail server syncs — including folders created by Outlook rules.
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- Account Card -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Email Account" Style="{StaticResource H3}" Margin="0,0,0,14"/>

                    <!-- Connected state -->
                    <Grid Visibility="{Binding IsSignedIn, Converter={StaticResource BoolToVisibility}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Width="44" Height="44" CornerRadius="22" Background="{StaticResource AccentBrush}">
                            <TextBlock Text="{Binding UserInitial}" FontSize="18" FontWeight="Bold"
                                       Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding UserName}" FontSize="14" FontWeight="Medium"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="{Binding UserEmail}" Style="{StaticResource Caption}"/>
                            <TextBlock>
                                <Run Text="✅ " Foreground="{StaticResource SuccessBrush}"/>
                                <Run Text="Connected via IMAP" Foreground="{StaticResource SuccessBrush}" FontWeight="Medium"/>
                            </TextBlock>
                        </StackPanel>
                        <Button Grid.Column="2" Content="Disconnect" Style="{StaticResource GhostButton}"
                                Command="{Binding SignOutCommand}" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Connect form -->
                    <StackPanel Visibility="{Binding IsSignedIn, Converter={StaticResource InverseBoolToVisibility}}">
                        <TextBlock Style="{StaticResource Body}" Margin="0,0,0,12" TextWrapping="Wrap">
                            Enter your email credentials. Passwords are encrypted locally with Windows DPAPI.
                            Most providers require an app-specific password when two-factor authentication is enabled.
                        </TextBlock>

                        <TextBlock Text="Provider" Style="{StaticResource Caption}" Margin="0,0,0,6"/>
                        <ComboBox ItemsSource="{Binding ProviderOptions}"
                                  SelectedItem="{Binding SelectedProvider}"
                                  Width="320" HorizontalAlignment="Left" Margin="0,0,0,12"/>

                        <TextBlock Text="{Binding ConnectionHint}" FontSize="11"
                                   Foreground="{StaticResource WarningBrush}" TextWrapping="Wrap"
                                   Margin="0,0,0,12"/>

                        <!-- OAuth sign-in (Gmail / Microsoft) — also shown for Custom when domain detected -->
                        <StackPanel Visibility="{Binding ShowOAuthButtons, Converter={StaticResource BoolToVisibility}}"
                                    Margin="0,0,0,12">
                            <Border Background="#33F5A623" CornerRadius="6" Padding="10" Margin="0,0,0,10"
                                    Visibility="{Binding ShowMicrosoftOAuth, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource TextPrimaryBrush}">
                                    Hotmail/Outlook: password login is blocked by Microsoft. You MUST use the button below — your IMAP/SMTP settings are already correct.
                                </TextBlock>
                            </Border>
                            <TextBlock Text="Required for Hotmail/Gmail — sign in via browser" Style="{StaticResource Caption}" Margin="0,0,0,8"/>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Sign in with Google" Style="{StaticResource PrimaryButton}"
                                        Click="SignInGoogle_Click" Margin="0,0,8,0"
                                        Visibility="{Binding ShowGoogleOAuth, Converter={StaticResource BoolToVisibility}}"/>
                                <Button Content="Sign in with Microsoft" Style="{StaticResource PrimaryButton}"
                                        Click="SignInMicrosoft_Click"
                                        Visibility="{Binding ShowMicrosoftOAuth, Converter={StaticResource BoolToVisibility}}"/>
                            </StackPanel>
                            <TextBlock Text="Approval appears in your browser — not inside this app. Configure OAuth Client IDs in Settings first."
                                       FontSize="10" Foreground="{StaticResource TextMutedBrush}"
                                       TextWrapping="Wrap" Margin="0,8,0,0"/>
                        </StackPanel>

                        <TextBlock Text="Or use App Password" Style="{StaticResource Caption}" Margin="0,0,0,8"
                                   Visibility="{Binding ShowOAuthButtons, Converter={StaticResource BoolToVisibility}}"/>

                        <TextBlock Text="Email address" Style="{StaticResource Caption}" Margin="0,0,0,6"/>
                        <TextBox Style="{StaticResource DarkTextBox}" Text="{Binding AccountEmail, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,12"/>

                        <TextBlock Text="Password / App password" Style="{StaticResource Caption}" Margin="0,0,0,6"/>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <PasswordBox x:Name="MailPasswordBox" Height="38" Padding="10,0"
                                         Background="{StaticResource SurfaceElevatedBrush}"
                                         Foreground="{StaticResource TextPrimaryBrush}"
                                         BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                         PasswordChar="●"/>
                            <Button Grid.Column="1" Content="Connect" Style="{StaticResource PrimaryButton}"
                                    Click="ConnectAccount_Click" Margin="8,0,0,0" Padding="16,8"/>
                        </Grid>

                        <StackPanel Visibility="{Binding ShowCustomServers, Converter={StaticResource BoolToVisibility}}"
                                    Margin="0,0,0,8">
                            <TextBlock Text="Custom server settings" Style="{StaticResource Caption}" Margin="0,0,0,8"/>
                            <TextBlock Text="IMAP server" Style="{StaticResource Caption}" Margin="0,0,0,4"/>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Style="{StaticResource DarkTextBox}" Text="{Binding ImapHost}"/>
                                <TextBox Grid.Column="1" Style="{StaticResource DarkTextBox}" Text="{Binding ImapPort}"
                                         Margin="8,0,0,0"/>
                            </Grid>
                            <TextBlock Text="IMAP encryption" Style="{StaticResource Caption}" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding EncryptionOptions}"
                                      SelectedItem="{Binding SelectedImapEncryption}"
                                      Width="280" HorizontalAlignment="Left" Margin="0,0,0,8"/>
                            <TextBlock Text="SMTP server" Style="{StaticResource Caption}" Margin="0,0,0,4"/>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Style="{StaticResource DarkTextBox}" Text="{Binding SmtpHost}"/>
                                <TextBox Grid.Column="1" Style="{StaticResource DarkTextBox}" Text="{Binding SmtpPort}"
                                         Margin="8,0,0,0"/>
                            </Grid>
                            <TextBlock Text="SMTP encryption" Style="{StaticResource Caption}" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding EncryptionOptions}"
                                      SelectedItem="{Binding SelectedSmtpEncryption}"
                                      Width="280" HorizontalAlignment="Left"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Sync Control Card -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <Grid Margin="0,0,0,14">
                        <TextBlock Text="Synchronization" Style="{StaticResource H3}"/>
                        <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                            <Button Content="↻ Sync Now" Style="{StaticResource PrimaryButton}"
                                    Command="{Binding SyncNowCommand}"
                                    IsEnabled="{Binding CanSync}"
                                    Padding="14,8"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Sync emails from" Style="{StaticResource Caption}" Margin="0,0,0,6"/>
                    <ComboBox ItemsSource="{Binding AvailableSyncPeriods}"
                              SelectedItem="{Binding SelectedSyncPeriod}"
                              Width="220" HorizontalAlignment="Left" Margin="0,0,0,6"/>
                    <TextBlock Style="{StaticResource Caption}" Foreground="{StaticResource TextMutedBrush}"
                               TextWrapping="Wrap" Margin="0,0,0,12">
                        Only messages within this period are downloaded on the first sync per folder. Later syncs fetch new mail only.
                        All mailbox folders sync (Inbox, Sent, and custom/rule folders) when Settings → Sync all folders is enabled.
                    </TextBlock>

                    <ProgressBar Value="{Binding SyncProgress}" Maximum="100" Margin="0,0,0,8"
                                 Visibility="{Binding IsSyncing, Converter={StaticResource BoolToVisibility}}"
                                 Height="6"/>
                    <TextBlock Text="{Binding SyncStatusText}" Style="{StaticResource Body}"
                               Margin="0,0,0,16" Foreground="{StaticResource TextSecondaryBrush}"/>

                    <TextBlock Text="Folder Status" Style="{StaticResource H3}" Margin="0,0,0,10"/>
                    <ItemsControl ItemsSource="{Binding FolderStates}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Ellipse Grid.Column="0" Width="8" Height="8" Margin="0,0,10,0"
                                             VerticalAlignment="Center" Fill="{Binding StatusColor, Converter={StaticResource HexToBrush}}"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding FolderName}" FontSize="13"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="{Binding LastSyncText}" Style="{StaticResource Caption}"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="2" Text="{Binding TotalSynced}" FontSize="13"
                                               Foreground="{StaticResource AccentBrush}" FontWeight="Medium"
                                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Grid.Column="3" Text="emails" Style="{StaticResource Caption}"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Sync log -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <Grid Margin="0,0,0,10">
                        <TextBlock Text="Sync Log" Style="{StaticResource H3}"/>
                        <Button Content="Clear" HorizontalAlignment="Right" Style="{StaticResource GhostButton}"
                                Command="{Binding ClearLogCommand}" FontSize="11" Padding="10,4"/>
                    </Grid>
                    <Border Background="{StaticResource SurfaceElevatedBrush}" CornerRadius="6" Padding="12">
                        <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                            <TextBlock Text="{Binding SyncLog}" FontFamily="{StaticResource MonoFont}"
                                       FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                       TextWrapping="Wrap"/>
                        </ScrollViewer>
                    </Border>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
