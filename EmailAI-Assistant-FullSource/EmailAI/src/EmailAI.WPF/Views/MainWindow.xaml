<Window x:Class="EmailAI.WPF.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:EmailAI.WPF.Views"
        xmlns:vm="clr-namespace:EmailAI.UI.Shared.ViewModels"
        Title="EmailAI Assistant"
        Height="820" Width="1280"
        MinHeight="650" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource PrimaryBrush}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ── Sidebar ──────────────────────────────────────────────── -->
        <Border Grid.Column="0"
                Background="{StaticResource NavBgBrush}"
                BorderBrush="{StaticResource BorderSubtleBrush}"
                BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Logo -->
                <Border Grid.Row="0" Padding="20,20,20,16">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="32" Height="32" CornerRadius="8"
                                Background="{StaticResource AccentBrush}">
                            <TextBlock Text="✉" FontSize="16" HorizontalAlignment="Center"
                                       VerticalAlignment="Center" Foreground="White"/>
                        </Border>
                        <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="EmailAI" FontSize="15" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="Assistant" FontSize="10"
                                       Foreground="{StaticResource TextMutedBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- User info -->
                <Border Grid.Row="1" Margin="12,0,12,12" Padding="10,8" CornerRadius="8"
                        Background="{StaticResource SurfaceElevatedBrush}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="28" Height="28" CornerRadius="14"
                                Background="{StaticResource AccentBrush}">
                            <TextBlock Text="{Binding UserInitial}" FontSize="13" FontWeight="Bold"
                                       Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding UserName}" FontSize="12" FontWeight="Medium"
                                       Foreground="{StaticResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding UserEmail}" FontSize="10"
                                       Foreground="{StaticResource TextMutedBrush}" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Navigation -->
                <StackPanel Grid.Row="2" Margin="8,0">
                    <TextBlock Text="M E N U" FontSize="10" FontWeight="SemiBold" Margin="14,8,0,4"
                               Foreground="{StaticResource TextMutedBrush}"/>

                    <Button Style="{StaticResource NavButton}"
                            Command="{Binding NavigateCommand}" CommandParameter="Dashboard">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⊞" FontSize="16" Width="24" VerticalAlignment="Center"/>
                            <TextBlock Text="Dashboard" Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource NavButton}"
                            Command="{Binding NavigateCommand}" CommandParameter="Chat">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💬" FontSize="15" Width="24" VerticalAlignment="Center"/>
                            <TextBlock Text="AI Chat" Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource NavButton}"
                            Command="{Binding NavigateCommand}" CommandParameter="Inbox">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="📧" FontSize="15" Width="24" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="Mail" Margin="8,0,0,0" VerticalAlignment="Center"/>
                            <Border Grid.Column="2" Style="{StaticResource UnreadBadge}"
                                    Visibility="{Binding HasUnread, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Text="{Binding UnreadCount}" FontSize="10" FontWeight="Bold"
                                           Foreground="White" HorizontalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Button>

                    <Button Style="{StaticResource NavButton}"
                            Command="{Binding NavigateCommand}" CommandParameter="Search">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔍" FontSize="15" Width="24" VerticalAlignment="Center"/>
                            <TextBlock Text="Search" Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource NavButton}"
                            Command="{Binding NavigateCommand}" CommandParameter="Sync">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="↻" FontSize="16" Width="24" VerticalAlignment="Center"/>
                            <TextBlock Text="Sync" Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Bottom actions -->
                <StackPanel Grid.Row="3" Margin="8,0,8,4">
                    <Separator/>
                    <Button Style="{StaticResource NavButton}"
                            Command="{Binding NavigateCommand}" CommandParameter="Settings">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚙" FontSize="16" Width="24" VerticalAlignment="Center"/>
                            <TextBlock Text="Settings" Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Sync status -->
                <Border Grid.Row="4" Margin="12,0,12,12" Padding="10,8" CornerRadius="8"
                        Background="{StaticResource SurfaceElevatedBrush}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <Ellipse Width="6" Height="6" Margin="0,0,6,0" VerticalAlignment="Center"
                                     Fill="{Binding SyncStatusColor, Converter={StaticResource HexToBrush}}"/>
                            <TextBlock Text="{Binding SyncStatusText}" FontSize="11"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                        <TextBlock Text="{Binding LastSyncText}" FontSize="10"
                                   Foreground="{StaticResource TextMutedBrush}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ── Content Area ─────────────────────────────────────────── -->
        <ContentControl Grid.Column="1"
                        Content="{Binding CurrentView}"
                        Margin="0"/>
    </Grid>
</Window>
