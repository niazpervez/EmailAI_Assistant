<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="EmailAI.MAUI.Pages.SyncPage"
             Title="Sync"
             BackgroundColor="#1A1F2E">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="12">
            <Label Text="Connect your email account" TextColor="#F0F2F8" FontAttributes="Bold"/>
            <Entry Text="{Binding AccountEmail}" Placeholder="Email address" Keyboard="Email" TextColor="#F0F2F8" BackgroundColor="#252B3B"/>
            <Picker Title="Provider" ItemsSource="{Binding ProviderOptions}" SelectedItem="{Binding SelectedProvider}" TextColor="#F0F2F8"/>
            <Entry x:Name="PasswordEntry" IsPassword="True" Placeholder="Password or app password" TextColor="#F0F2F8" BackgroundColor="#252B3B"/>
            <Button Text="Connect" Clicked="ConnectAccount_Click" BackgroundColor="#4F8EF7"/>
            <Button Text="Sign in with Google" Command="{Binding SignInGoogleCommand}" BackgroundColor="#2D3548" TextColor="#F0F2F8"/>
            <Button Text="Sign in with Microsoft" Command="{Binding SignInMicrosoftCommand}" BackgroundColor="#2D3548" TextColor="#F0F2F8"/>
            <Button Text="Sync Now" Command="{Binding SyncNowCommand}" BackgroundColor="#3ECF8E" TextColor="#1A1F2E"/>
            <Label Text="{Binding SyncStatusText}" TextColor="#8B95B0"/>
            <Editor Text="{Binding SyncLog}" IsReadOnly="True" HeightRequest="240" TextColor="#8B95B0" BackgroundColor="#252B3B"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
